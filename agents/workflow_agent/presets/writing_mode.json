  "actions": [
    {"action_type": "launch_app", "name": "Open Editor", "target": "notepad", "order": 1},
    {"action_type": "launch_app", "name": "Open Browser", "target": "chrome", "order": 2},
    {"action_type": "open_url", "name": "Open Grammarly", "target": "https://www.grammarly.com", "order": 3},
    {"action_type": "set_notifications", "name": "Enable Focus Mode", "target": "focus", "order": 4},
    {"action_type": "start_timer", "name": "Start Writing Timer", "target": "pomodoro", "params": {"duration": 30}, "order": 5}
