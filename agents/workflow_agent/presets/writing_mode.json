{
  "name": "Writing Mode",
  "description": "Distraction-free writing environment with focus mode and grammar tools",
  "icon": "pen",
  "category": "creative",
  "aliases": ["writing", "write", "author", "draft", "blog", "article"],
  "apps_to_launch": ["notepad", "chrome"],
