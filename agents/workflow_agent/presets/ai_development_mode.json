{
  "name": "AI Development Mode",
  "description": "AI/ML development workspace with Ollama, model monitoring, and API testing",
  "icon": "robot",
  "category": "development",
  "aliases": ["ai dev", "ai development", "ml", "machine learning", "ollama", "llm"],
  "apps_to_launch": ["vscode", "terminal", "chrome"],
  "urls_to_open": [
    "http://localhost:11434",
    "https://huggingface.co"
  ],
  "agents_to_activate": ["coding_agent", "terminal_agent"],
  "notifications_mode": "focus",
  "focus_mode": true,
  "timer_duration": 45,
  "priority": 9,
  "tags": ["ai", "ml", "ollama", "llm", "development", "model"],
  "actions": [
    {"action_type": "launch_app", "name": "Open VS Code", "target": "vscode", "order": 1},
    {"action_type": "launch_app", "name": "Open Terminal", "target": "terminal", "order": 2},
    {"action_type": "launch_app", "name": "Open Browser", "target": "chrome", "order": 3},
    {"action_type": "open_url", "name": "Open Ollama Dashboard", "target": "http://localhost:11434", "order": 4},
    {"action_type": "open_url", "name": "Open Hugging Face", "target": "https://huggingface.co", "order": 5},
    {"action_type": "activate_agent", "name": "Activate Coding Agent", "target": "coding_agent", "order": 6},
    {"action_type": "activate_agent", "name": "Activate Terminal Agent", "target": "terminal_agent", "order": 7},
    {"action_type": "set_notifications", "name": "Enable Focus Mode", "target": "focus", "order": 8},
    {"action_type": "start_timer", "name": "Start Deep Work Timer", "target": "pomodoro", "params": {"duration": 45}, "order": 9}
  ]
}
